---
import content from '../data/content.json';
import SectionHeader from './ui/SectionHeader.astro';
import GridBackground from './ui/GridBackground.astro';
---

<section id="nosotros" class="relative py-32 overflow-hidden">
  <GridBackground />

  <div class="glow-blob w-[500px] h-[500px] bg-accent/10 top-1/2 left-0 -translate-y-1/2 -translate-x-1/2 animate-glow-pulse" />

  <div class="section-container relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div>
        <SectionHeader
          title={content.about.title}
          subtitle={content.about.description}
          class="text-left mb-8"
        />

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
          {content.about.features.map((feature) => (
            <div class="rounded-card bg-surface/30 border border-zinc-800/50 p-4">
              <h4 class="text-sm font-semibold text-accent mb-1">{feature.title}</h4>
              <p class="text-xs text-zinc-500 leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          {content.about.stats.map((stat) => (
            <div>
              <div class="text-2xl md:text-3xl font-bold text-gradient mb-1">{stat.value}</div>
              <div class="text-xs text-zinc-500">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="aspect-[4/3] rounded-card bg-surface border-gradient overflow-hidden flex items-center justify-center">
          <div class="text-center p-8">
            <div class="w-20 h-20 rounded-2xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
              </svg>
            </div>
            <p class="text-zinc-500 text-sm">Planta de producción en Guadalajara</p>
          </div>
        </div>

        <div class="absolute -bottom-4 -right-4 w-32 h-32 rounded-card bg-accent/5 border border-accent/10 flex items-center justify-center">
          <div class="text-center">
            <div class="text-2xl font-bold text-accent">45+</div>
            <div class="text-xs text-zinc-500">Años</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
