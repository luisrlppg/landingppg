---
import content from '../data/content.json';
import Button from './ui/Button.astro';
import GridBackground from './ui/GridBackground.astro';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <GridBackground />

  <div class="glow-blob w-[600px] h-[600px] bg-accent/20 top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 animate-glow-pulse" />
  <div class="glow-blob w-[400px] h-[400px] bg-accent-glow/10 top-1/3 right-1/4 animate-glow-pulse animate-delay-200" />

  <div class="section-container relative z-10 pt-32 pb-20 text-center">
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-accent text-xs font-medium mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        Desde 1976 en Guadalajara
      </div>
    </div>

    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] mb-6 animate-slide-up">
      {content.hero.title.split(' ').map((word, i) => {
        if (word.toLowerCase() === 'cosméticos' || word.toLowerCase() === 'marca') {
          return <span class="text-gradient">{word} </span>;
        }
        return <span>{word} </span>;
      })}
    </h1>

    <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto mb-10 animate-slide-up animate-delay-200">
      {content.hero.subtitle}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up animate-delay-300">
      <Button href="#productos" variant="primary">
        {content.hero.cta}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </Button>
      <Button href="#contacto" variant="secondary">
        {content.hero.ctaSecondary}
      </Button>
    </div>

    <div class="mt-20 animate-fade-in animate-delay-500">
      <div class="inline-flex items-center gap-8 text-sm text-zinc-500">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Calidad certificada
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Envío a todo Latam
        </div>
        <div class="hidden sm:flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Desde 1976
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-black to-transparent"></div>
</section>
