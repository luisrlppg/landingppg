---
import content from '../data/content.json';
import Button from './ui/Button.astro';
import GridBackground from './ui/GridBackground.astro';
---

<section id="contacto" class="relative py-16 md:py-32 overflow-hidden">
  <GridBackground />

  <div class="glow-blob w-[600px] h-[600px] bg-accent/15 bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 animate-glow-pulse" />

  <div class="section-container relative z-10">
    <div class="max-w-4xl lg:max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-4" data-aos="fade-up">
        {content.contact.title}
      </h2>
      <p class="text-zinc-400 text-lg mb-8 md:mb-12" data-aos="fade-up" data-aos-delay="100">
        {content.contact.subtitle}
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8 md:mb-12">
        <div class="rounded-card bg-surface/50 border-gradient p-5" data-aos="zoom-in" data-aos-delay="200">
          <div class="w-11 h-11 rounded-lg bg-accent/10 flex items-center justify-center mx-auto mb-2">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="text-sm text-zinc-400">{content.contact.email}</p>
        </div>

        <div class="rounded-card bg-surface/50 border-gradient p-5" data-aos="zoom-in" data-aos-delay="300">
          <div class="w-11 h-11 rounded-lg bg-accent/10 flex items-center justify-center mx-auto mb-2">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <p class="text-sm text-zinc-400">{content.contact.phone}</p>
        </div>

        <div class="rounded-card bg-surface/50 border-gradient p-5" data-aos="zoom-in" data-aos-delay="400">
          <div class="w-11 h-11 rounded-lg bg-accent/10 flex items-center justify-center mx-auto mb-2">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <p class="text-sm text-zinc-400">{content.contact.address}</p>
        </div>

        <div class="rounded-card bg-surface/50 border-gradient p-5" data-aos="zoom-in" data-aos-delay="500">
          <div class="w-11 h-11 rounded-lg bg-accent/10 flex items-center justify-center mx-auto mb-2">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <p class="text-sm text-zinc-400">{content.contact.hours}</p>
        </div>
      </div>

      <div class="rounded-card bg-surface/50 border-gradient p-6 md:p-8 lg:p-12" data-aos="fade-up" data-aos-delay="300">
        <form class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left">
          <div>
            <label class="block text-sm font-medium text-zinc-300 mb-2">Nombre</label>
            <input
              type="text"
              class="w-full px-4 py-3 rounded-xl bg-zinc-900/50 border border-zinc-800 text-white text-base focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-zinc-300 mb-2">Email</label>
            <input
              type="email"
              class="w-full px-4 py-3 rounded-xl bg-zinc-900/50 border border-zinc-800 text-white text-base focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
              placeholder="tu@email.com"
            />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-zinc-300 mb-2">Empresa</label>
            <input
              type="text"
              class="w-full px-4 py-3 rounded-xl bg-zinc-900/50 border border-zinc-800 text-white text-base focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
              placeholder="Nombre de tu empresa"
            />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-zinc-300 mb-2">Mensaje</label>
            <textarea
              rows="4"
              class="w-full px-4 py-3 rounded-xl bg-zinc-900/50 border border-zinc-800 text-white text-base focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors resize-none"
              placeholder="Cuéntanos sobre tu proyecto..."
            ></textarea>
          </div>
          <div class="md:col-span-2 flex flex-col sm:flex-row gap-3">
            <Button variant="primary" class="flex-1">
              Enviar mensaje
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </Button>
            <Button href={`https://wa.me/${content.contact.whatsapp}?text=${encodeURIComponent(content.contact.whatsappMessage)}`} variant="secondary" class="flex-1">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </Button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
