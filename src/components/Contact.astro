---
import content from '../data/content.json';
import Button from './ui/Button.astro';
import GridBackground from './ui/GridBackground.astro';
---

<section id="contacto" class="relative py-32 overflow-hidden">
  <GridBackground />

  <div class="glow-blob w-[600px] h-[600px] bg-accent/15 bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 animate-glow-pulse" />

  <div class="section-container relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
        {content.contact.title}
      </h2>
      <p class="text-zinc-400 text-lg mb-12">
        {content.contact.subtitle}
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="rounded-card bg-surface/50 border-gradient p-6">
          <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="text-sm text-zinc-400">{content.contact.email}</p>
        </div>

        <div class="rounded-card bg-surface/50 border-gradient p-6">
          <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <p class="text-sm text-zinc-400">{content.contact.phone}</p>
        </div>

        <div class="rounded-card bg-surface/50 border-gradient p-6">
          <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <p class="text-sm text-zinc-400">{content.contact.address}</p>
        </div>
      </div>

      <div class="rounded-card bg-surface/50 border-gradient p-8 md:p-12">
        <form class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left">
          <div>
            <label class="block text-sm font-medium text-zinc-300 mb-2">Nombre</label>
            <input
              type="text"
              class="w-full px-4 py-3 rounded-xl bg-zinc-900/50 border border-zinc-800 text-white text-sm focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-zinc-300 mb-2">Email</label>
            <input
              type="email"
              class="w-full px-4 py-3 rounded-xl bg-zinc-900/50 border border-zinc-800 text-white text-sm focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
              placeholder="tu@email.com"
            />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-zinc-300 mb-2">Empresa</label>
            <input
              type="text"
              class="w-full px-4 py-3 rounded-xl bg-zinc-900/50 border border-zinc-800 text-white text-sm focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors"
              placeholder="Nombre de tu empresa"
            />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-zinc-300 mb-2">Mensaje</label>
            <textarea
              rows="4"
              class="w-full px-4 py-3 rounded-xl bg-zinc-900/50 border border-zinc-800 text-white text-sm focus:outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/50 transition-colors resize-none"
              placeholder="Cuéntanos sobre tu proyecto..."
            ></textarea>
          </div>
          <div class="md:col-span-2">
            <Button variant="primary" class="w-full">
              Enviar mensaje
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </Button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
