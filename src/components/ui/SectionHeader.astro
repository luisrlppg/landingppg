---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = '' } = Astro.props;
---

<div class:list={['text-center mb-10 md:mb-16', className]} data-aos="fade-up">
  <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
    {title}
  </h2>
  {subtitle && (
    <p class="text-zinc-400 text-base sm:text-lg max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
