---
import content from '../data/content.json';
import SectionHeader from './ui/SectionHeader.astro';
import GridBackground from './ui/GridBackground.astro';
const v = Date.now();
---

<section id="nosotros" class="relative py-16 md:py-32 overflow-hidden">
  <GridBackground />

  <div class="glow-blob w-[500px] h-[500px] bg-accent/10 top-1/2 left-0 -translate-y-1/2 -translate-x-1/2 animate-glow-pulse" />

  <div class="section-container relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <div data-aos="fade-right">
        <SectionHeader
          title={content.about.title}
          subtitle={content.about.description}
          class="text-left mb-8"
        />

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-6 md:mb-10">
          {content.about.features.map((feature, i) => (
            <div class="rounded-card bg-surface/30 border border-zinc-800/50 p-4 sm:p-5" data-aos="fade-up" data-aos-delay={String((i + 1) * 100)}>
              <h4 class="text-sm md:text-base font-semibold text-accent mb-1">{feature.title}</h4>
              <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          {content.about.stats.map((stat, i) => (
            <div data-aos="fade-up" data-aos-delay={String((i + 4) * 100)}>
              <div class="text-2xl md:text-3xl font-bold text-gradient mb-1">{stat.value}</div>
              <div class="text-xs text-zinc-500">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="relative" data-aos="fade-left" data-aos-delay="200">
        <div class="aspect-[4/3] rounded-card bg-surface border-gradient overflow-hidden">
          <img
            src={`/images/placeholder-planta.png?v=${v}`}
            alt="Planta de producción en Guadalajara"
            width="800"
            height="600"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <div class="mt-4 inline-flex items-center gap-3 rounded-card bg-accent/5 border border-accent/10 px-5 py-3">
          <div class="text-2xl font-bold text-accent">50+</div>
          <div class="text-xs text-zinc-500">Años de<br/>experiencia</div>
        </div>
      </div>
    </div>
  </div>
</section>
