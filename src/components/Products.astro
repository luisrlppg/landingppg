---
import content from '../data/content.json';
import GlowCard from './ui/GlowCard.astro';
import SectionHeader from './ui/SectionHeader.astro';
import GridBackground from './ui/GridBackground.astro';
---

<section id="productos" class="relative py-32 overflow-hidden">
  <GridBackground />

  <div class="section-container relative z-10">
    <SectionHeader
      title="Nuestros Productos"
      subtitle="Soluciones completas para la industria cosmética, desde envases hasta herramientas de aplicación."
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {content.products.map((product) => (
        <GlowCard class="p-6 group">
          <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>

          <h3 class="text-lg font-semibold mb-2">{product.title}</h3>
          <p class="text-zinc-400 text-sm leading-relaxed">{product.description}</p>

          <div class="mt-4 pt-4 border-t border-zinc-800/50">
            <span class="text-accent text-sm font-medium group-hover:underline cursor-pointer">
              Ver opciones →
            </span>
          </div>
        </GlowCard>
      ))}
    </div>
  </div>
</section>
