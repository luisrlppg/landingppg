---
import content from '../data/content.json';
---

<footer class="relative border-t border-zinc-800/50 py-12">
  <div class="section-container">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-accent/20 flex items-center justify-center">
          <span class="text-accent font-bold text-sm">PP</span>
        </div>
        <span class="font-semibold text-lg tracking-tight">{content.company.name}</span>
      </div>

      <div class="flex items-center gap-6">
        {content.footer.links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>

      <p class="text-sm text-zinc-600">
        {content.footer.copyright}
      </p>
    </div>
  </div>
</footer>
