---
import content from '../data/content.json';
---

<footer class="relative border-t border-zinc-800/50 py-12">
  <div class="section-container">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <img src="/ppg.jpg" alt="Plásticos Plasa" width="32" height="32" class="h-8 w-8 rounded-lg object-cover" />
        <div>
          <span class="font-semibold text-lg tracking-tight">{content.company.name}</span>
          <p class="text-xs text-zinc-600">{content.footer.tagline}</p>
        </div>
      </div>

      <div class="flex items-center gap-6 md:gap-8">
        {content.footer.links.map((link) => (
          <a
            href={link.href}
            class="text-sm md:text-base text-zinc-500 hover:text-zinc-300 transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a href={content.contact.instagram} target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-zinc-300 transition-colors" aria-label="Instagram">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
      </div>

      <p class="text-sm text-zinc-600">
        © {new Date().getFullYear()} {content.company.fullName}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
