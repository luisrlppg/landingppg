---
import content from '../data/content.json';
import GlowCard from './ui/GlowCard.astro';
import SectionHeader from './ui/SectionHeader.astro';
import GridBackground from './ui/GridBackground.astro';
---

<section id="testimonios" class="relative py-16 md:py-32">
  <GridBackground />

  <div class="glow-blob w-[500px] h-[500px] bg-accent/10 top-1/2 right-0 -translate-y-1/2 translate-x-1/2 animate-glow-pulse" />

  <div class="section-container relative z-10">
    <SectionHeader
      title="Lo que dicen nuestros clientes"
      subtitle="Marcas que confían en nosotros para crear sus envases."
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {content.testimonials.map((testimonial, i) => (
        <GlowCard class="p-6 flex flex-col" data-aos="fade-up" data-aos-delay={String(i * 100)}>
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="text-zinc-300 text-sm leading-relaxed flex-1 italic">
            "{testimonial.quote}"
          </p>

          <div class="mt-6 pt-4 border-t border-zinc-800/50 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center text-accent font-semibold text-sm">
              {testimonial.name.charAt(0)}
            </div>
            <div>
              <div class="text-sm font-medium">{testimonial.name}</div>
              <div class="text-xs text-zinc-500">{testimonial.company}</div>
            </div>
          </div>
        </GlowCard>
      ))}
    </div>
  </div>
</section>
