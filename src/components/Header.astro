---
import content from '../data/content.json';
import Button from './ui/Button.astro';
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="section-container">
    <nav class="flex items-center justify-between h-16 md:h-20">
      <button
        id="mobile-toggle"
        class="md:hidden p-3 text-zinc-400 hover:text-white shrink-0"
        aria-label="Menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 9h16.5m-16.5 6.75h16.5" />
        </svg>
      </button>

      <a href="/" class="flex items-center gap-2">
        <img src="/ppg.jpg" alt="Plásticos Plasa" width="32" height="32" class="h-8 w-8 rounded-lg object-cover shrink-0" />
        <span class="hidden sm:inline font-semibold text-lg tracking-tight">{content.company.name}</span>
      </a>

      <div class="flex-1"></div>

      <ul class="hidden md:flex items-center gap-8">
        {content.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm text-zinc-400 hover:text-white transition-colors duration-200"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="hidden md:flex items-center gap-3 shrink-0">
        <a href={content.contact.instagram} target="_blank" rel="noopener noreferrer" class="p-2 text-zinc-400 hover:text-white transition-colors" aria-label="Instagram">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <Button href="https://plasticosplasa.ventaenlinea.store" variant="primary">Cotizar ahora</Button>
      </div>

      <Button href="https://plasticosplasa.ventaenlinea.store" variant="primary" class="md:hidden shrink-0">Cotizar</Button>
    </nav>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-zinc-950/95 backdrop-blur-xl border-t border-zinc-800/50">
    <div class="section-container py-4 flex flex-col gap-3">
      <ul class="flex flex-col gap-1">
        {content.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-base text-zinc-400 hover:text-white py-3.5 transition-colors"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <Button href="https://plasticosplasa.ventaenlinea.store" variant="primary" class="mt-2">Cotizar ahora</Button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('bg-black/80', 'backdrop-blur-xl', 'border-b', 'border-zinc-800/50');
    } else {
      header?.classList.remove('bg-black/80', 'backdrop-blur-xl', 'border-b', 'border-zinc-800/50');
    }
  });

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
