---
import content from '../data/content.json';
import Button from './ui/Button.astro';
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="section-container">
    <nav class="flex items-center justify-between h-16 md:h-20">
      <a href="/" class="flex items-center gap-2">
        <img src="/ppg.jpg" alt="Plásticos Plasa" class="h-8 w-8 rounded-lg object-cover" />
        <span class="font-semibold text-lg tracking-tight">{content.company.name}</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {content.nav.map((item) => (
          <a
            href={item.href}
            class="text-sm text-zinc-400 hover:text-white transition-colors duration-200"
          >
            {item.label}
          </a>
        ))}
      </div>

      <div class="hidden md:flex items-center gap-3">
        <a href={content.contact.instagram} target="_blank" rel="noopener noreferrer" class="p-2 text-zinc-400 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <Button href="#contacto" variant="primary">Cotizar ahora</Button>
      </div>

      <button
        id="mobile-toggle"
        class="md:hidden p-2 text-zinc-400 hover:text-white"
        aria-label="Menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 9h16.5m-16.5 6.75h16.5" />
        </svg>
      </button>
    </nav>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-zinc-950/95 backdrop-blur-xl border-t border-zinc-800/50">
    <div class="section-container py-4 flex flex-col gap-3">
      {content.nav.map((item) => (
        <a
          href={item.href}
          class="text-sm text-zinc-400 hover:text-white py-2 transition-colors"
        >
          {item.label}
        </a>
      ))}
      <Button href="#contacto" variant="primary" class="mt-2">Cotizar ahora</Button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('bg-black/80', 'backdrop-blur-xl', 'border-b', 'border-zinc-800/50');
    } else {
      header?.classList.remove('bg-black/80', 'backdrop-blur-xl', 'border-b', 'border-zinc-800/50');
    }
  });

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
